<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Members only</title>
    <style>
      body {
        font-family: sans-serif;
        max-width: 760px;
        margin: 2rem auto;
        padding: 0 1rem;
      }

      nav {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
      }

      .logout-form {
        margin: 0;
      }

      article {
        border: 1px solid #d4d4d4;
        border-radius: 6px;
        padding: 1rem;
        margin-bottom: 0.9rem;
      }

      h2 {
        margin-top: 0;
        margin-bottom: 0.5rem;
      }

      .message-text {
        white-space: pre-wrap;
      }

      .message-meta {
        color: #555;
        font-size: 0.95rem;
      }
    </style>
  </head>
  <body>
    <h1>Members only</h1>

    <nav>
      <a href="/">Home</a>
      <% if (currentUser) { %>
      <a href="/messages/new">Create a new message</a>
      <a href="/membership/join">Join the club</a>
      <form class="logout-form" action="/auth/logout" method="post">
        <button type="submit">Log out</button>
      </form>
      <% } else { %>
      <a href="/auth/login">Log in</a>
      <a href="/auth/sign-up">Sign up</a>
      <% } %>
    </nav>

    <% if (messages.length === 0) { %>
    <p>No messages yet.</p>
    <% } %>

    <% messages.forEach((message) => { %>
    <article>
      <h2><%= message.title %></h2>
      <p class="message-text"><%= message.text %></p>

      <% if (canSeeDetails) { %>
      <p class="message-meta">
        By <%= message.author_first_name %> <%= message.author_last_name %> on
        <%= new Date(message.created_at).toLocaleString() %>
      </p>
      <% } %>
    </article>
    <% }) %>
  </body>
</html>
