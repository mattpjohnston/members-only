<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Members only</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="page-shell">
      <h1>Members only</h1>

      <nav class="nav">
        <a href="/">Home</a>
        <% if (currentUser) { %>
        <a href="/messages/new">Create a new message</a>
        <% if (!isMember && !isAdmin) { %>
        <a href="/membership/join">Join the club</a>
        <% } %>
        <% if (!isAdmin) { %>
        <a href="/admin/join">Become admin</a>
        <% } %>
        <form class="unstyled-form" action="/auth/logout" method="post">
          <button type="submit">Log out</button>
        </form>
        <% } else { %>
        <a href="/auth/login">Log in</a>
        <a href="/auth/sign-up">Sign up</a>
        <% } %>
      </nav>

      <% if (successMessage) { %>
      <p class="success-banner"><%= successMessage %></p>
      <% } %>

      <% if (infoMessage) { %>
      <p class="info-banner"><%= infoMessage %></p>
      <% } %>

      <% if (currentUser) { %>
      <p class="account-status">
        Logged in as <strong><%= currentUser.firstName ?? "User" %></strong>.
        Member: <strong><%= isMember ? "Yes" : "No" %></strong> | Admin:
        <strong><%= isAdmin ? "Yes" : "No" %></strong>
      </p>
      <% } else { %>
      <p class="account-status">
        You are browsing as a guest. Log in to create messages.
      </p>
      <% } %>

      <% if (messages.length === 0) { %>
      <p class="empty-state">No messages yet.</p>
      <% } %>

      <% messages.forEach((message) => { %>
      <article class="card">
        <h2><%= message.title %></h2>
        <p class="message-text"><%= message.text %></p>

        <% if (canSeeDetails) { %>
        <p class="message-meta">
          By <%= message.author_first_name %> <%= message.author_last_name %> on
          <%= new Date(message.created_at).toLocaleString() %>
        </p>
        <% } %>

        <% if (canDeleteMessages) { %>
        <form
          class="unstyled-form"
          action="/messages/<%= message.id %>/delete"
          method="post"
        >
          <button class="button-danger" type="submit">Delete message</button>
        </form>
        <% } %>
      </article>
      <% }) %>
    </main>
  </body>
</html>
