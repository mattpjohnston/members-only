<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Log in</title>
    <style>
      body {
        font-family: sans-serif;
        max-width: 640px;
        margin: 2rem auto;
        padding: 0 1rem;
      }

      form {
        display: grid;
        gap: 0.75rem;
      }

      label {
        display: grid;
        gap: 0.25rem;
      }

      input {
        padding: 0.5rem;
      }

      .error {
        color: #b91c1c;
      }
    </style>
  </head>
  <body>
    <h1>Log in</h1>

    <% if (formError) { %>
    <p class="error" role="alert"><%= formError %></p>
    <% } %>

    <form action="/auth/login" method="post">
      <label>
        Email
        <input type="email" name="email" required />
      </label>

      <label>
        Password
        <input type="password" name="password" required />
      </label>

      <button type="submit">Log in</button>
    </form>
  </body>
</html>
